{
  "expo": {
    "newArchEnabled": true,
    "name": "NotesContract",
    "slug": "NotesContract",
    "scheme": "notescontract",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#0D87E1"
    },
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      }
    },
    "web": {
      "bundler": "metro",
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      [
        "expo-router",
        {
          "root": "./src/app"
        }
      ],
      "expo-font",
      "expo-secure-store",
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "DermaDoc needs your location to show accurate UV index and sun exposure data.",
          "locationAlwaysAndWhenInUsePermission": "DermaDoc needs your location to show accurate UV index and sun exposure data."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
